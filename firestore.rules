rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Core helper functions (ABAC primitives)
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Document-specific validation blueprints
    function isValidInvoice(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.invoiceNumber is string && data.invoiceNumber.size() <= 200;
    }

    // 4. Secured pathways
    match /invoices/{invoiceId} {
      // List rules: MUST check resource.data to prevent unauthorized client query scanning
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(invoiceId)
        && isValidInvoice(incoming())
        && incoming().userId == request.auth.uid;
        
      allow update: if isSignedIn()
        && isValidId(invoiceId)
        && isValidInvoice(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == request.auth.uid;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
